# Node / Build
node_modules/
apps/**/node_modules/
.next/
apps/**/.next/

# API build output
apps/api/dist/

# TypeScript 增量构建缓存
*.tsbuildinfo
apps/**/*.tsbuildinfo

# Uploaded media (MVP：不提交到仓库)
apps/api/uploads/

# Environment / secrets
.env
.env.*
apps/api/.env
# 例外：环境变量模板必须入库（供团队参考）
!.env.example
!apps/api/.env.example

# 本地开发脚本运行日志与 PID（scripts/dev-up.sh 产物）
.dev-logs/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local caches
.npm-cache/
apps/**/.npm-cache/
**/npm-cache/

# 测试与覆盖率（预留）
coverage/
.nyc_output/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
