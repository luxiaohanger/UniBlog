# ===== UniBlog API 后端环境变量模板 =====
# 使用方式：通常由 scripts/up.sh 自动从本文件创建/合并 apps/api/.env；也可手动 cp 后修改
# 重要：apps/api/.env 已被 .gitignore 忽略，请勿把真实密钥提交到仓库

# ----- 数据库 -----
# Docker Compose 开发：API 容器内由 compose 注入 DATABASE_URL（指向服务名 postgres），
# 此处可保留默认值。若用宿主机工具（如 Prisma Studio、psql）连库，请使用 up.sh 写入的
# UNIBLOG_PG_PORT，例如：postgresql://postgres:postgres@localhost:<宿主机端口>/uniblog
# 容器内 API 始终连 postgres:5432，与宿主机映射端口无关。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uniblog"

# ----- HTTP -----
# API 在容器内的监听端口（与 compose 一致）；浏览器访问的宿主机端口以 scripts/up.sh 输出为准
PORT=4000

# ----- JWT -----
# 生产环境必须修改为随机强密钥，建议：openssl rand -hex 48
JWT_ACCESS_SECRET=dev_access_secret
# Access Token 有效期，支持 jsonwebtoken 的简写：15m / 2h / 24h / 7d
JWT_ACCESS_EXPIRES_IN=24h
# Refresh Token 过期天数（入库的记录）
JWT_REFRESH_EXPIRES_DAYS=30

# ----- CORS -----
# 逗号分隔的白名单；留空则开发环境默认放行 http://localhost:*
# 生产必须显式配置：CORS_ORIGIN=https://your.domain
CORS_ORIGIN=

# ----- SMTP（注册 / 重置密码验证码）-----
# 以 QQ 邮箱为例：SMTP_HOST=smtp.qq.com, SMTP_PORT=465, SMTP_SECURE=true
# SMTP_PASS 需要填 QQ 邮箱「IMAP/SMTP 服务」的授权码（不是登录密码）
# 163 邮箱同理：smtp.163.com / 465 / true；Gmail：smtp.gmail.com / 587 / false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# 发件人展示：建议与 SMTP_USER 同域；留空则自动使用 "UniBlog <SMTP_USER>"
SMTP_FROM=

# ----- 调试 -----
# 设为任意非空值开启 Prisma 的 query + error 日志
PRISMA_LOG=
