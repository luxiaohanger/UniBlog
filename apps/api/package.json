{
  "name": "@uniblog/api",
  "private": true,
  "version": "0.0.1",
  "type": "commonjs",
  "scripts": {
    "predev": "npm run build -w @uniblog/shared",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run build -w @uniblog/shared",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
