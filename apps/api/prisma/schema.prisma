generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// 举报目标类型：post 帖子 / comment 评论 / user 用户
enum ReportTargetType {
  post
  comment
  user
}

/// 举报处理状态：open 待审核 / resolved 已通过（目标已处理）/ rejected 驳回
enum ReportStatus {
  open
  resolved
  rejected
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  /// 权限：user 普通用户；admin 管理员（可删任意帖与单条评论）
  role         String   @default("user")
  createdAt    DateTime @default(now())
  /// 展示名；为空时前端回退到 username
  displayName  String?
  /// 简介，建议 <= 200 字
  bio          String?
  /// 头像相对路径，形如 uploads/avatar-<ts>-<rand>.<ext>
  avatarPath   String?

  refreshTokens RefreshToken[]
  posts         Post[]
  comments      Comment[]
  postLikes     PostLike[]
  postFavorites PostFavorite[]
  postShares    PostShare[]

  sentFriendships     Friendship[] @relation("FriendshipSender")
  receivedFriendships Friendship[] @relation("FriendshipReceiver")

  sentMessages     ChatMessage[] @relation("ChatMessageSender")
  receivedMessages ChatMessage[] @relation("ChatMessageReceiver")

  receivedSystemNotifications SystemNotification[] @relation("SystemNotificationRecipient")
  sentSystemNotifications     SystemNotification[] @relation("SystemNotificationActor")

  filedReports    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportTargetUser")
  reviewedReports Report[] @relation("ReportReviewer")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

/// 邮箱验证码（用于注册校验、找回密码等场景）
/// 不与 User 关联：注册场景下用户尚未创建；找回密码场景同样以邮箱为准。
model EmailVerification {
  id         String    @id @default(cuid())
  email      String
  /// 验证码的 sha256 哈希，原码不落库
  codeHash   String
  /// 用途：register / reset_password
  purpose    String
  /// 错误尝试次数，达到阈值即作废
  attempts   Int       @default(0)
  expiresAt  DateTime
  /// 消费时间：成功校验后写入，防重放
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// 圈子页置顶时间（仅管理员可操作，全局最多 3 篇）
  pinnedInFeedAt DateTime?
  /// 作者主页/我的帖子置顶时间（仅作者可操作，每人最多 3 篇）
  pinnedInProfileAt DateTime?

  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     PostMedia[]
  comments  Comment[]
  likes     PostLike[]
  favorites PostFavorite[]
  shares    PostShare[]

  @@index([pinnedInFeedAt])
  @@index([authorId, pinnedInProfileAt])
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  kind      String
  path      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Comment {
  id           String    @id @default(cuid())
  postId       String
  authorId     String
  content      String
  /// 回复所属「层主」评论 id；顶层主评为空
  layerMainId  String?
  createdAt    DateTime  @default(now())

  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  layerRoot  Comment?  @relation("CommentLayer", fields: [layerMainId], references: [id], onDelete: SetNull)
  layerReplies Comment[] @relation("CommentLayer")

  @@index([postId])
  @@index([layerMainId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostFavorite {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostShare {
  id        String   @id @default(cuid())
  postId    String
  sharerId  String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  sharer User @relation(fields: [sharerId], references: [id], onDelete: Cascade)

  @@unique([postId, sharerId])
  @@index([postId])
  @@index([sharerId])
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  sender   User @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  sender   User @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ChatMessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, senderId, createdAt])
}

model SystemNotification {
  id          String   @id @default(cuid())
  recipientId String
  actorId     String?
  kind        String
  content     String?
  postId      String?
  commentId   String?
  createdAt   DateTime @default(now())

  recipient User  @relation("SystemNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("SystemNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([postId])
  @@index([commentId])
}

/// 用户举报：按目标类型分三类，由管理员审核
/// - targetType=post/comment：同一举报人对同一目标只允许一条 open 举报（应用层去重）
/// - targetType=user：同一举报人对同一被举报用户只允许一条 open 举报
/// - 审核通过（resolved）会触发删帖 / 删单条评论（由应用层执行），并写入 SystemNotification
model Report {
  id            String           @id @default(cuid())
  reporterId    String
  targetType    ReportTargetType
  /// 关联目标 id：post -> Post.id，comment -> Comment.id，user -> User.id
  targetId      String
  /// 被举报用户（冗余存储以便管理员检索与排序；删用户时置空，保留历史）
  targetUserId  String?
  /// 举报原因文案，<= 200 字（业务层校验）
  reason        String
  status        ReportStatus     @default(open)
  /// 审核人 id（管理员），处理后填入；管理员被删时置空
  reviewerId    String?
  /// 审核人留言，可为空
  reviewerNote  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())

  reporter   User  @relation("ReportReporter",   fields: [reporterId],   references: [id], onDelete: Cascade)
  targetUser User? @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  reviewer   User? @relation("ReportReviewer",   fields: [reviewerId],   references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId, createdAt])
  @@index([targetUserId, status])
}
